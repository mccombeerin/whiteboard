{
  "name": "TutorBlocks",
  "version": "2.0.0",
  "description": "A shared whiteboard canvas for kids tutoring sessions. Tutor places locked letter/word blocks and drop zones. Students drag blocks into the zones.",
  "supportUrl": "https://your-domain.com/support",
  "privacyPolicyUrl": "https://your-domain.com/privacy",
  "termsOfServiceUrl": "https://your-domain.com/terms",

  "scopes": [
    "meeting:read",
    "user:read"
  ],

  "capabilities": [
    "getMeetingContext",
    "getUserContext",
    "getRunningContext",
    "sendAppInvitation",
    "onMessage",
    "openUrl"
  ],

  "domains": [
    "https://your-domain.netlify.app"
  ],

  "inMeeting": {
    "defaultSize": {
      "width": 900,
      "height": 640
    },
    "minSize": {
      "width": 700,
      "height": 500
    }
  },

  "homeUrl": "https://your-domain.netlify.app/index.html",
  "entryPointUrl": "https://your-domain.netlify.app/index.html",

  "sdkVersion": "0.16",

  "roles": [
    "host",
    "coHost",
    "attendee"
  ],

  "zoomAppsVersion": "2"
}
